{
  "name": "@quejugamos/api",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "import:curated": "node scripts/import-curated-games.mjs",
    "import:curated:bgg": "node scripts/import-curated-games.mjs --bgg",
    "api:docs:generate": "pnpm build && node scripts/generate-api-docs.mjs",
    "api:docs:check": "pnpm build && node scripts/generate-api-docs.mjs --check",
    "post-feature": "pnpm api:docs:generate && pnpm typecheck && pnpm test && pnpm api:docs:check",
    "hooks:install": "husky",
    "prepare": "husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "pnpm build && node --test \"dist/**/*.spec.js\" \"scripts/**/*.test.mjs\""
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "6.11.1",
    "cache-manager": "^7.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "9.0.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^24.0.10",
    "husky": "9.1.7",
    "openapi-to-postmanv2": "6.3.0",
    "prisma": "6.11.1",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@scarf/scarf"
    ]
  }
}
