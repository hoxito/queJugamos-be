NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
FRONTEND_AUTH_CALLBACK_URL=http://localhost:8081/auth/callback

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=quejugamos
DATABASE_PASSWORD=quejugamos
DATABASE_NAME=quejugamos
DATABASE_URL=postgresql://quejugamos:quejugamos@localhost:5432/quejugamos
DATABASE_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
GAMES_QUERY_CACHE_TTL_SECONDS=60
GAMES_QUERY_CACHE_MAX_ENTRIES=200
GAMES_DETAIL_CACHE_TTL_SECONDS=120
GAMES_DETAIL_CACHE_MAX_ENTRIES=500
GAMES_FILTERS_CACHE_TTL_SECONDS=300
GAMES_FILTERS_CACHE_MAX_ENTRIES=20
BACKEND_ERROR_LOG_FILE=

AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_JWT_ISSUER=quejugamos
